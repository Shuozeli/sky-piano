# Sky Piano - Default Key Mapping
#
# Maps Sky key positions (0-14) to keyboard keys.
# Edit this file and pass --mapping to sky-piano to use custom mapping.
#
# Default: 15-key positional mapping matching Sky's 3x5 grid
# Key 0-4:  Y U I O P (top row)
# Key 5-9:  H J K L ; (middle row)
# Key 10-14: N M , . / (bottom row)

[mapping]
"0" = "y"
"1" = "u"
"2" = "i"
"3" = "o"
"4" = "p"
"5" = "h"
"6" = "j"
"7" = "k"
"8" = "l"
"9" = ";"
"10" = "n"
"11" = "m"
"12" = ","
"13" = "."
"14" = "/"
